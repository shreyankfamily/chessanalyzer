{
  "manifest_version": 3,
  "name": "ChessAnalyzer Bridge",
  "version": "0.2.1",
  "description": "Reads the live chess position from ChessTempo or Lichess (no screenshots) and opens it in ChessAnalyzer for engine analysis.",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": [
    "https://chesstempo.com/*",
    "https://*.chesstempo.com/*",
    "https://lichess.org/*",
    "https://*.lichess.org/*",
    "https://shreyankfamily.github.io/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "ChessAnalyzer Bridge"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chesstempo.com/*",
        "https://*.chesstempo.com/*",
        "https://lichess.org/*",
        "https://*.lichess.org/*"
      ],
      "js": ["extract.js", "content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://shreyankfamily.github.io/chessanalyzer/*"],
      "js": ["bridge.js"],
      "run_at": "document_idle"
    }
  ]
}
